{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "required": [
        "retrofit_id"
    ],
    "properties": {
        "retrofit_id": {
            "type": "integer",
            "default": "0"
        },
        "retrofit_potential": {
            "type": "number",
            "default": "0.0"
        },
        "retrofit_fraction": {
            "type": "number"
        }
    }
}