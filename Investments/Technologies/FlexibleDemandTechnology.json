{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "required": [
        "name",
        "available",
        "power_systems_type"
    ],
    "properties": {
        "name": {
            "type": "string"
        },
        "id": {
            "type": "integer"
        },
        "available": {
            "type": "boolean"
        },
        "power_systems_type": {
            "type": "string"
        },
        "max_demand_delay": {
            "type": "number"
        },
        "max_demand_advance": {
            "type": "number"
        },
        "demand_energy_efficiency": {
            "type": "number"
        },
        "var_cost_per_mwh": {
            "$ref": "../../Core/common.json#/definitions/ValueCurve"
        }
    }
}