{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "required": [
        "name",
        "available"
    ],
    "properties": {
        "name": {
            "type": "string"
        },
        "base_year": {
          "type": "integer",
          "default": "2020"
        },
        "id": {
            "type": "integer"
        },
        "available": {
            "type": "boolean"
        },
        "base_power": {
          "type": "number"
        },
        "power_systems_type": {
            "type": "string"
        },
        "start_region": {
          "type": "integer"
        },
        "end_region": {
          "type": "integer"
        },
        "existing_line_capacity": {
            "type": "number"
        },
        "maximum_new_capacity": {
            "type": "number"
        },
        "capital_cost": {
            "$ref": "../../Core/common.json#/definitions/ValueCurve"
        },
        "line_loss": {
            "type": "number"
        },
        "resistance": {
            "type": "number",
            "default": "0.0"
        },
        "voltage": {
            "type": "number",
            "default": "0.0"
        },
        "angle_limit": {
            "type": "number",
            "default": "0.0"
        },
        "financial_data": {
            "type": "integer"
        }
    }
}