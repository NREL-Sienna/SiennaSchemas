{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "required": [
        "name",
        "capital_recovery_period",
        "technology_base_year"
    ],
    "properties": {
        "name": {
            "type": "string"
        },
        "interest_rate": {
            "type": "number",
            "default": "0.0"
        },
        "capital_recovery_period": {
            "type": "integer"
        },
        "technology_base_year": {
            "type": "integer"
        },
        "id": {
            "type": "integer"
        }
    }
  }