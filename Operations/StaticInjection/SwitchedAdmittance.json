{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "properties": {
    "id": {
      "type": "integer"
    },
    "name": {
      "type": "string"
    },
    "available": {
      "type": "boolean"
    },
    "bus": {
      "type": "integer"
    },
    "Y": {
      "$ref": "../../Core/common.json#/definitions/ComplexNumber"
    },
    "initial_status": {
      "type": "array",
      "items": {
        "type": "integer"
      }
    },
    "number_of_steps": {
      "type": "array",
