{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "properties": {
    "id": {
      "type": "integer"
    },
    "name": {
      "type": "string"
    },
    "available": {
      "type": "boolean"
    },
    "storage_level_limits": {
      "$ref": "../../Core/common.json#/definitions/MinMax"
    },
    "initial_level": {
      "type": "number"
    },
    "spillage_limits": {
      "descriptor": "in psy5 a required param with an option to be nothing",
      "$ref": "../../Core/common.json#/definitions/MinMax"
    },
    "inflow": {
      "type": "number"
    },
    "outflow": {
      "type": "number"
    },
    "level_targets": {
      "descriptor": "in psy5 a required param with an option to be nothing",
      "type": "number"
    },
    "intake_elevation": {
      "type": "number"
    },
    "head_to_volume_factor": {
      "$ref": "../../Core/common.json#/definitions/ValueCurve"
    }, 
    "upstream_turbines": {
      "type": "array",
      "items": {
        "type": "integer"
      }
    },
    "downstream_turbines": {
      "type": "array",
      "items": {
        "type": "integer"
      }
    },
    "upstream_reservoirs": {
      "type": "array",
      "items": {
        "type": "integer"
      }
    },
    "operation_cost": {
      "descriptor": "default PSY.HydroReservoirCost(nothing), I think already in common.json?",
      "$ref": "../../Core/common.json#/definitions/HydroReservoirCost"
    }, 
    "level_data_type": {
      "$ref": "../../Core/common.json#/definitions/ReservoirDataType",
      "default": "USABLE_VOLUME"
    }
  },
  "required": [
    "id",
    "name",
    "available",
    "storage_level_limits",
    "initial_level",
    "inflow",
    "outflow",
    "intake_elevation",
    "head_to_volume_factor",
    "operation_cost"
  ],
  "title": "HydroReservoir",
  "type": "object"
}
