{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "properties": {
    "id": {
      "type": "integer"
    },
    "name": {
      "type": "string"
    },
    "available": {
      "type": "boolean"
    },
    "active_power_flow": {
      "type": "number"
    },
    "reactive_power_flow": {
      "type": "number"
    },
    "arc": {
      "type": "integer"
    },
    "r": {
      "type": "number"
    },
    "x": {
      "type": "number"
    },
    "primary_shunt": {
      "$ref": "../../Core/common.json#/definitions/ComplexNumber"
    },
    "tap": {
      "type": "number"
    },
    "rating": {
      "type": "number"
    },
    "base_power": {
      "type": "number"
    },
    "base_voltage_primary": {
      "descriptor": "default of get_base_voltage(get_from(arc)))",
      "type": "number"
    },
    "base_voltage_secondary": {
      "descriptor": "default of get_base_voltage(get_to(arc)))",
      "type": "number"
    },
    "rating_b": {
      "type": "number"
    },
    "rating_c": {
      "type": "number"
    },
    "winding_group_number": {
      "default": "UNDEFINED",
      "$ref": "../../Core/common.json#/definitions/WindingGroupNumber"
    },
    "control_objective": {
      "default": "UNDEFINED",
      "$ref": "../../Core/common.json#/definitions/TransformerControlObjective"
    }
  },
  "required": [
    "id",
    "name",
    "available",
    "active_power_flow",
    "reactive_power_flow",
    "arc",
    "r",
    "x",
    "primary_shunt",
    "tap",
    "base_power"
  ],
  "title": "TapTransformer",
  "type": "object"
}
