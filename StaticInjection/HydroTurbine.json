{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "properties": {
    "id": {
      "type": "integer"
    },
    "name": {
      "type": "string"
    },
    "available": {
      "type": "boolean"
    },
    "bus": {
      "type": "integer"
    },
    "active_power": {
      "type": "number"
    },
    "reactive_power": {
      "type": "number"
    },
    "rating": {
      "type": "number"
    },
    "active_power_limits": {
      "$ref": "../common.json#/definitions/MinMax"
    },
    "reactive_power_limits": {
      "descriptor": "in psy5 a required param with an option to be nothing",
      "$ref": "../common.json#/definitions/MinMax"
    },
    "base_power": {
      "type": "number"
    },
    "operation_cost": {
      "descriptor": "or MarketBidCost; default PSY.HydroGenerationCost(nothing)",
      "default": {
        "variable": {
          "variable_cost_type": "COST",
          "value_curve": {
            "curve_type": "INPUT_OUTPUT",
            "function_data": {
              "function_type": "LINEAR",
              "constant_term": 0,
              "proportional_term": 0
            },
            "input_at_zero": 0
          },
          "vom_cost": {
            "curve_type": "INPUT_OUTPUT",
            "function_data": {
              "function_type": "LINEAR",
              "constant_term": 0,
              "proportional_term": 0
            },
            "input_at_zero": 0
          }
        }
      },
      "$ref": "../common.json#/definitions/HydroGenerationCost"
    },
    "powerhouse_elevation": {
      "default": 0.0,
      "type": "number"
    },
    "ramp_limits": {
      "$ref": "../common.json#/definitions/UpDown"
    },
    "time_limits": {
      "$ref": "../common.json#/definitions/UpDown"
    },
    "outflow_limits": {
      "$ref": "../common.json#/definitions/MinMax"
    },
    "efficiency": {
      "default": 1.0,
      "type": "number"
    },
    "turbine_type": {
      "default": "UNKNOWN",
      "$ref": "../common.json#/definitions/HydroTurbineType"
    },
    "conversion_factor": {
      "default": 1.0,
      "type": "number"
    },
    "prime_mover_type": {
      "$ref": "../common.json#/definitions/PrimeMovers",
      "default": "HY"
    },
    "travel_time": {
      "type": "number"
    },
    "dynamic_injector": {
      "type": null
    }
  },
  "required": [
    "id",
    "name",
    "available",
    "bus",
    "active_power",
    "reactive_power",
    "rating",
    "active_power_limits",
    "base_power",
    "operation_cost"
  ],
  "title": "HydroTurbine",
  "type": "object"
}
