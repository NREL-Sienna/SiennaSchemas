{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "properties": {
    "id": {
      "type": "integer"
    },
    "name": {
      "type": "string"
    },
    "available": {
      "type": "boolean"
    },
    "bus": {
      "type": "integer"
    },
    "active_power": {
      "default": 0.0,
      "type": "number"
    },
    "reactive_power": {
      "default": 0.0,
      "type": "number"
    },
    "active_power_limits": {
      "default": {
        "min": 0.0,
        "max": 0.0
      },
      "$ref": "../common.json#/definitions/MinMax"
    },
    "reactive_power_limits": {
      "default": {
        "min": 0.0,
        "max": 0.0
      },
      "$ref": "../common.json#/definitions/MinMax"
    },
    "R_th": {
      "default": 0.0,
      "type": "number"
    },
    "X_th": {
      "default": 0.0,
      "type": "number"
    },
    "internal_voltage": {
      "default": 1.0,
      "type": "number"
    },
    "internal_angle": {
      "default": 0.0,
      "type": "number"
    },
    "base_power": {
      "default": 100.0,
      "type": "number"
    },
    "operation_cost": {
      "descriptor": "default PSY.ImportExportCost(nothing)",
      "default": {
        "import_offer_curves": {
          "variable_cost_type": "COST",
          "value_curve": {
            "curve_type": "INPUT_OUTPUT",
            "function_data": {
              "function_type": "LINEAR",
              "constant_term": 0,
              "proportional_term": 0
            },
            "input_at_zero": 0
          },
          "vom_cost": {
            "curve_type": "INPUT_OUTPUT",
            "function_data": {
              "function_type": "LINEAR",
              "constant_term": 0,
              "proportional_term": 0
            },
            "input_at_zero": 0
          } 
        },
        "export_offer_curves": {
          "variable_cost_type": "COST",
          "value_curve": {
            "curve_type": "INPUT_OUTPUT",
            "function_data": {
              "function_type": "LINEAR",
              "constant_term": 0,
              "proportional_term": 0
            },
            "input_at_zero": 0
          },
          "vom_cost": {
            "curve_type": "INPUT_OUTPUT",
            "function_data": {
              "function_type": "LINEAR",
              "constant_term": 0,
              "proportional_term": 0
            },
            "input_at_zero": 0
          } 
        },
        "energy_import_weekly_limit": 1000000.0,
        "energy_export_weekly_limit": 1000000.0
      },
      "$ref": "../common.json#/definitions/ImportExportCost"
    },
    "dynamic_injector": {
      "type": null
    }
  },
  "required": [
    "id",
    "name",
    "available",
    "bus",
    "operation_cost"
  ],
  "title": "Source",
  "type": "object"
}
