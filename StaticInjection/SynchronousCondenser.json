{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "properties": {
    "id": {
      "type": "integer"
    },
    "name": {
      "type": "string"
    },
    "available": {
      "type": "boolean"
    },
    "bus": {
      "type": "integer"
    },
    "reactive_power": {
      "type": "number"
    },
    "rating": {
      "type": "number"
    },
    "reactive_power_limits": {
      "descriptor": "in psy5 a required param with an option to be nothing",
      "$ref": "../common.json#/definitions/MinMax"
    },
    "base_power": {
      "type": "number"
    },
    "active_power_losses": {
      "default": 0.0,
      "type": "number"
    },
    "dynamic_injector": {
      "type": null
    }
  },
  "required": [
    "id",
    "name",
    "bus",
    "available",
    "reactive_power",
    "rating",
    "base_power"
  ],
  "title": "SynchronousCondenser",
  "type": "object"
}
