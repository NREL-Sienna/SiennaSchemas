{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "properties": {
    "id": {
      "type": "integer"
    },
    "name": {
      "type": "string"
    },
    "available": {
      "type": "boolean"
    },
    "status": {
      "type": "boolean"
    },
    "bus": {
      "type": "integer"
    },
    "active_power": {
      "type": "number"
    },
    "reactive_power": {
      "type": "number"
    },
    "rating": {
      "type": "number"
    },
    "active_power_limits": {
      "$ref": "../common.json#/definitions/MinMax"
    },
    "reactive_power_limits": {
      "$ref": "../common.json#/definitions/MinMax"
    },
    "ramp_limits": {
      "$ref": "../common.json#/definitions/UpDown"
    },
    "operation_cost": {
      "descriptor": "or MarketBidCost",
      "$ref": "../common.json#/definitions/ThermalGenerationCost"
    },
    "base_power": {
      "default": 0.0,
      "type": "number"
    },
    "time_limits": {
      "$ref": "../common.json#/definitions/UpDown"
    },
    "must_run": {
      "default": false,
      "title": "Must Run",
      "type": "boolean"
    },
    "prime_mover_type": {
      "$ref": "../common.json#/definitions/PrimeMovers",
      "default": "OT"
    },
    "fuel_type": {
      "$ref": "../common.json#/definitions/ThermalFuels",
      "default": "OTHER"
    },
    "time_at_status": {
      "default": 10000.0,
      "type": "number"
    },
    "dynamic_injector": {
      "type": null
    }
  },
  "required": [
    "id",
    "name",
    "available",
    "status",
    "bus",
    "active_power",
    "reactive_power",
    "rating",
    "active_power_limits",
    "operation_cost",
    "base_power"
  ],
  "title": "ThermalStandard",
  "type": "object"
}
