{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "required": [
        "name",
        "available",
        "power_systems_type"
    ],
    "properties": {
        "name": {
            "type": "string"
        },
        "id": {
            "type": "integer"
        },
        "available": {
            "type": "boolean"
        },
        "power_systems_type": {
            "type": "string"
        },
        "technology_efficiency": {
            "type": "number",
            "default": "0.0"
        },
        "price_per_unit": {
            "type": "number",
            "default": "0.0"
        },
        "min_power": {
            "type": "number",
            "default": "0.0"
        },
        "ramp_up_percentage": {
            "type": "number",
            "default": "1.0"
        },
        "ramp_dn_percentage": {
            "type": "number",
            "default": "1.0"
        }
    }
}