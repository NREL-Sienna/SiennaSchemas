{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "required": [
        "name",
        "available",
        "power_systems_type"
    ],
    "properties": {
        "name": {
            "type": "string"
        },
        "id": {
            "type": "integer"
        },
        "available": {
            "type": "boolean"
        },
        "power_systems_type": {
            "type": "string"
        },
        "voll": {
            "type": "number"
        },
        "segments": {
            "type": "array",
            "items": {
                "type": "integer"
            }
        },
        "curtailment_cost": {
            "type": "array",
            "items": {
                "type": "number"
            }
        },
        "max_demand_curtailment": {
            "type": "array",
            "items": {
                "type": "number"
            }
        },
        "curtailment_cost_mwh": {
            "type": "array",
            "items": {
                "type": "number"
            }
        }
    }
}