{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "required": [
        "name",
        "available",
        "power_systems_type"
    ],
    "properties": {
        "name": {
            "type": "string"
        },
        "power_systems_type": {
            "type": "string"
        },
        "region": {
            "type": "array",
            "items": {
                "type": "integer"
            }
        },
        "id": {
            "type": "integer"
        },
        "available": {
            "type": "boolean"
        },
        "prime_mover_type": {
            "$ref": "../common.json#/definitions/PrimeMovers",
            "default": "OT"
        },
        "fuel": {
            "type": "array",
            "items": {
                "$ref": "../common.json#/definitions/ThermalFuels"
            }
        },
        "co2": {
            "type": "object",
            "additionalProperties": {
                "type": "number"
            }
        },
        "cofire_start_limits": {
            "type": "object",
            "additionalProperties": {
                "$ref": "../common.json#/definitions/MinMax"
            }
        },
        "cofire_level_limits": {
            "type": "object",
            "additionalProperties": {
                "$ref": "../common.json#/definitions/MinMax"
            }
        },
        "capital_costs": {
            "$ref": "../common.json#/definitions/ValueCurve"
        },
        "operation_costs": {
            "discriminator": {
                "mapping": {
                  "THERMAL": "../common.json#/definitions/ThermalGenerationCost",
                  "RENEWABLE": "../common.json#/definitions/RenewableGenerationCost"
                },
                "propertyName": "cost_type"
            },
            "oneOf":[
                {
                    "$ref": "../common.json#/definitions/ThermalGenerationCost"
                },
                {
                    "$ref": "../common.json#/definitions/RenewableGenerationCost"
                }
            ]
        },
        "unit_size": {
            "type": "number",
            "default": "0.0"
        },
        "capacity_limits": {
            "$ref": "../common.json#/definitions/MinMax"
        },
        "outage_factor": {
            "type": "number",
            "default": "1.0"
        },
        "min_generation_fraction": {
            "type": "number",
            "default": "0.0"
        },
        "ramp_limits": {
            "$ref": "../common.json#/definitions/UpDown"
        },
        "time_limits": {
            "$ref": "../common.json#/definitions/UpDown"
        },
        "start_fuel_mmbtu_per_mw": {
            "type": "number",
            "default": "0.0"
        },
        "lifetime": {
            "type": "integer",
            "default": "100"
        },
        "financial_data": {
            "$ref": "../common.json#/definitions/TechnologyFinancialData"
        }
    }
}