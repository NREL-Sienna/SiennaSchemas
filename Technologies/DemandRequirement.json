{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "required": [
        "name",
        "available",
        "power_systems_type"
    ],
    "properties": {
        "name": {
            "type": "string"
        },
        "id": {
            "type": "integer"
        },
        "available": {
            "type": "boolean",
            "default": "true"
        },
        "power_systems_type": {
            "type": "string"
        },
        "demand_mw": {
            "type": "number",
            "default": "0.0"
        },
        "region": {
            "type": "array",
            "items": {
                "type": "integer"
            }
        }
    }
}