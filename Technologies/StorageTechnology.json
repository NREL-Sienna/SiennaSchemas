{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "required": [
        "name",
        "available",
        "power_systems_type"
    ],
    "properties": {
        "name": {
            "type": "string"
        },
        "base_year": {
            "type": "integer"
        },
        "region": {
            "type": "array",
            "items": {
                "type": "integer"
            }
        },
        "id": {
            "type": "integer"
        },
        "available": {
            "type": "boolean"
        },
        "power_systems_type": {
            "type": "string"
        },
        "balancing_topology": {
            "type": "string"
        },
        "base_power": {
            "type": "number"
        },
        "prime_mover_type": {
            "$ref": "../common.json#/definitions/PrimeMovers",
            "default": "OT"
        },
        "storage_tech": {
            "$ref": "../common.json#/definitions/StorageTech"
        },
        "capital_costs_energy": {
            "$ref": "../common.json#/definitions/ValueCurve"
        },
        "capital_costs_power": {
            "$ref": "../common.json#/definitions/ValueCurve"
        },
        "operations_costs_energy": {
            "$ref": "../common.json#/definitions/StorageCost"
        },
        "operations_costs_power": {
            "$ref": "../common.json#/definitions/StorageCost"
        },
        "existing_capacity_power": {
            "type": "number",
            "default": "0.0"
        },
        "existing_capacity_energy": {
            "type": "number",
            "default": "0.0"
        },
        "unit_size_power": {
            "type": "number",
            "default": "0.0"
        },
        "unit_size_energy": {
            "type": "number",
            "default": "0.0"
        },
        "capacity_limits_power": {
            "$ref": "../common.json#/definitions/MinMax"
        },
        "capacity_limits_energy": {
            "$ref": "../common.json#/definitions/MinMax"
        },
        "duration_limits": {
            "$ref": "../common.json#/definitions/MinMax"
        },
        "efficiency": {
            "$ref": "../common.json#/definitions/InOut"
        },
        "losses": {
            "type": "number",
            "default": "1.0"
        },
        "lifetime": {
            "type": "integer",
            "default": "100"
        },
        "financial_data": {
            "type": "integer"
        }
    }
}