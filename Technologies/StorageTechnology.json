{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "required": [
        "name",
        "available",
        "power_systems_type"
    ],
    "properties": {
        "name": {
            "type": "string"
        },
        "region": {
            "type": "array",
            "items": {
                "type": "integer"
            }
        },
        "id": {
            "type": "integer"
        },
        "available": {
            "type": "boolean"
        },
        "power_systems_type": {
            "type": "string"
        },
        "min_discharge_fraction": {
            "type": "number",
            "default": "0.0"
        },
        "prime_mover_type": {
            "$ref": "../common.json#/definitions/PrimeMovers",
            "default": "OT"
        },
        "storage_tech": {
            "$ref": "../common.json#/definitions/StorageTech"
        },
        "capital_costs_energy": {
            "$ref": "../common.json#/definitions/ValueCurve"
        },
        "capital_costs_charge": {
            "$ref": "../common.json#/definitions/ValueCurve"
        },
        "capital_costs_discharge": {
            "$ref": "../common.json#/definitions/ValueCurve"
        },
        "operation_costs": {
            "$ref": "../common.json#/definitions/StorageCost"
        },
        "unit_size_discharge": {
            "type": "number",
            "default": "0.0"
        },
        "unit_size_charge": {
            "type": "number",
            "default": "0.0"
        },
        "unit_size_energy": {
            "type": "number",
            "default": "0.0"
        },
        "capacity_limits_charge": {
            "$ref": "../common.json#/definitions/MinMax"
        },
        "capacity_limits_discharge": {
            "$ref": "../common.json#/definitions/MinMax"
        },
        "capacity_limits_energy": {
            "$ref": "../common.json#/definitions/MinMax"
        },
        "duration_limits": {
            "$ref": "../common.json#/definitions/MinMax"
        },
        "efficiency": {
            "$ref": "../common.json#/definitions/InOut"
        },
        "losses": {
            "type": "number",
            "default": "1.0"
        },
        "lifetime": {
            "type": "integer",
            "default": "100"
        },
        "financial_data": {
            "$ref": "../common.json#/definitions/TechnologyFinancialData"
        }
    }
}