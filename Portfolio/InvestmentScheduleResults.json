{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "start_dates": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "end_dates": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "results": {
            "type": "array",
            "items": {
                "properties": {
                    "technology": {
                        "type": "string"
                    },
                    "parameter": {
                        "type": "string"
                    },
                    "name": {
                        "type": "string"
                    },
                    "installations": {
                        "type": "array",
                        "items": {
                            "type": "number"
                        }
                    }
                },
                "type": "object"
            }
        }
    }
}