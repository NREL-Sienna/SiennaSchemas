{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "required": [
        "name",
        "available",
        "eligible_resources"
    ],
    "properties": {
        "name": {
            "type": "string"
        },
        "id": {
            "type": "integer"
        },
        "available": {
            "type": "boolean"
        },
        "target_year": {
            "type": "integer"
        },
        "eligible_resources": {
            "type": "array",
            "items": {
                "type": "integer"
            }
        },
        "max_capacity_mw": {
            "type": "number"
        }
    }
}