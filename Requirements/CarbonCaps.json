{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "required": [
        "name",
        "available"
    ],
    "properties": {
        "name": {
            "type": "string"
        },
        "id": {
            "type": "integer"
        },
        "available": {
            "type": "boolean"
        },
        "power_systems_type": {
            "type": "string"
        },
        "eligible_zones": {
            "type": "array",
            "items": {
                "type": "integer"
            }
        },
        "co_2_max_tons_mwh": {
            "type": "number",
            "default": "1e8"
        },
        "co_2_max_mtons": {
            "type": "number"
        },
        "pricecap": {
            "type": "number",
            "default": "1e8"

        }
    }
}